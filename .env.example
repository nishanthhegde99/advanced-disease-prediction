# ============================================================================
# 🏥 Advanced Disease Prediction System v2.0 - Environment Configuration
# ============================================================================

# 🤖 AI INTEGRATION (Optional - Leave empty to use local knowledge base)
GOOGLE_API_KEY=
OPENAI_API_KEY=

# 📊 DATABASE
DATABASE_PATH=disease.db
DATABASE_TYPE=sqlite

# 🌐 FLASK
FLASK_ENV=development
FLASK_DEBUG=False
FLASK_PORT=5000
SECRET_KEY=your-secret-key-change-in-production

# 🔒 SECURITY
CORS_ORIGINS=http://localhost:5000
RATE_LIMIT=100

# 📈 SYSTEM
MAX_SYMPTOMS=5
MIN_CONFIDENCE_THRESHOLD=30
ENABLE_AI_INSIGHTS=True
ENABLE_LEARNING_ENGINE=True
ENABLE_PDF_EXPORT=True

# 🏥 HOSPITAL
ORGANIZATION_NAME=Your Hospital Name
SUPPORT_EMAIL=support@hospital.com
EMERGENCY_PHONE=911

# 🔍 MODELS
MODEL_FILE=disease_model.pkl
METRICS_FILE=model_metrics.json
